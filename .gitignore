# =========================================================
# LAN Atlas - .gitignore
# Python + AWS + agent/cloud app + optional frontend
# =========================================================

# ------------------------------
# OS / editor noise
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------
# Python
# ------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.nox/
.tox/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
dist/
build/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
.env/
env/
ENV/


# ------------------------------
# Logs / runtime files
# ------------------------------
logs/
*.log
*.out
*.err
*.pid
tmp/
temp/
.cache/

# ------------------------------
# Local databases / app state
# ------------------------------
*.db
*.sqlite
*.sqlite3
instance/
data/

# LAN Atlas-specific local runtime folders
agent-buffer/
agent-cache/
agent-state/
scan-results/
observations/
exports/
reports/
captures/
pcaps/

# Packet captures / local scan artifacts
*.pcap
*.pcapng
*.jsonl

# ------------------------------
# Secrets / local env
# Keep example files committed
# ------------------------------
.env
.env.*
!.env.example
!.env.sample

# Frontend env files if you add a dashboard frontend
frontend/.env
frontend/.env.*
!frontend/.env.example

# Common secret / certificate material
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
*.keystore
*.der

# Loose credential files
secrets.*
secret.*
credentials.*
creds.*

# ------------------------------
# AWS / cloud tooling
# ------------------------------
.aws/
.aws-sam/
serverless-state.json

# ------------------------------
# Terraform / IaC
# Only relevant if using Terraform
# ------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
terraform.tfvars
*.auto.tfvars

# ------------------------------
# Containers
# ------------------------------
docker-compose.override.yml

# ------------------------------
# Security / scan reports
# ------------------------------
bandit-report.*
safety-report.*
semgrep-report.*
trivy-report.*
junit.xml

# ------------------------------
# Node / frontend dashboard
# Only relevant if the dashboard uses Node
# ------------------------------
node_modules/
.npm/
.pnpm-store/
.next/
.nuxt/

# ------------------------------
# Generated artifacts / backups
# ------------------------------
artifacts/
generated/
*.bak
*.tmp

# ------------------------------
# Local scratch space
# ------------------------------
.local/
scratch/
playground/

# ------------------------------
# AI assistant local files
# Keep shared instructions if you want them in repo,
# but ignore personal/local assistant state
# ------------------------------
.claude/settings.local.json
.claude/project.local.json
.cursor/
